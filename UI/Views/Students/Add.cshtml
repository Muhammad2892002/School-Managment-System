@model Infrastructure.DTOs.StudentDTO
<head></head>
<body>

    @if (ViewBag.errorNumber > 0)
    {

        <div class="alert alert-danger">
            @foreach (var error in ViewBag.ErrorDetails)
            {
                <div>*@error</div>
                <br />

                
            }
        </div>
        
    
    
    }
    
    <form method="post" id="add-std-form" asp-controller="Students" asp-action="AddStd">

        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    First Name
                    <input name="firstName" asp-for=FirstName class=" form  form-control" />
                </div>
               

                <div class="col-md-4">
                    Last Name
                    <input name="LastName" asp-for=LastName class=" form  form-control" />
                </div>
                <div class="col-md-4">
                    Social Number
                    <input name="national" type="text" asp-for=NationalId class=" form  form-control" maxlength="10" minlength="10" pattern="\d{10}" />
                </div>
            </div>

            <div class="row">
                <div name="gender" class="  form  col-md-4">
                    Gender
                    <select asp-for=Gender class="form-select">
                        <option value="true">Male</option>
                        <option value="false">Female</option>
                    </select>
                </div>

                <div class="  form  col-md-4">
                    Birth Place
                    <select name="birthPlace" asp-for=Governorate class=" form  form-select" asp-items="@(new SelectList(ViewBag.Governorates, "Id", "Name"))">
                        <option value="null">Select a place</option>
                       
                    </select>
                </div>

                <div class="col-md-4">
                    Birth Date
                    <input name="birthDate" asp-for=BirthDate class=" form  form-control" type="date" />
                </div>

            </div>

          <div class="row">
             
              <div class="col-md-4">
                  <input type="submit" class="btn btn-outline-info" />

                  <a asp-action="Index" class="btn btn-outline-danger">Cancel</a>

              </div>
          </div>


        </div>
    </form>
    <script>
        document.addEventListener('DOMContentLoaded',function(){
           
            
           let form =document.getElementById("add-std-form");
           let inputs=document.querySelectorAll(".form");
           form.addEventListener('submit',function(e){
           e.preventDefault()
           validateInputs()
           }
           );

          function validateInputs(){
               
               inputs.forEach(input=>{
                   
                   if(input.value==''){
                     console.log(input.name+"is Empty")
                   
                   }
                   else{
                        console.log(input.name+"is Filled")
                   
                   
                   }
               
               
               })
           
           
           };

           
        
        
        
        });
    
    </script>
 



    
</body>